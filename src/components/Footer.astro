---
const today = new Date();
---

<footer>
	<div>
		<p class="footer-mark">Duojiang Field Notes</p>
		<p class="footer-copy">
			Travel, micro photography, reading, and small observations. <a href="https://duojianghuji.github.io/duojiang-research-page/">See research site</a>.
		</p>
	</div>
	<p class="footer-year">&copy; {today.getFullYear()} Duojiang.</p>
</footer>
<style>
	footer {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 4rem;
		padding: 1.5rem 1.5rem 2.5rem;
		border-top: 1px solid rgba(var(--line), 0.9);
		color: rgb(var(--muted));
	}

	.footer-mark {
		margin: 0 0 0.2rem;
		font-size: 0.88rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgb(var(--ink));
	}

	.footer-copy,
	.footer-year {
		margin: 0;
	}

	@media (max-width: 720px) {
		footer {
			padding: 1.25rem 0.9rem 2rem;
		}
	}
</style>
