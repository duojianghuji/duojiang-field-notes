---
const today = new Date();
---

<footer>
	<div>
		<p class="footer-mark">Duojiang Field Notes</p>
		<p class="footer-copy">
			Travel, micro photography, reading, and small observations.
		</p>
	</div>
	<p class="footer-year">&copy; {today.getFullYear()} Duojiang.</p>
</footer>
<style>
	footer {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 4rem;
		padding: 0 1.5rem 2.5rem;
		color: rgb(var(--muted));
	}

	.footer-mark {
		margin: 0 0 0.2rem;
		font-family: "Avenir Next Condensed", "Arial Narrow", "Trebuchet MS", sans-serif;
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgb(var(--ink));
	}

	.footer-copy,
	.footer-year {
		margin: 0;
	}

	@media (max-width: 720px) {
		footer {
			padding: 0 0.9rem 2rem;
		}
	}
</style>
