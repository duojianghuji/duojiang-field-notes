---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="site-mark" href="/">
			<span class="site-kicker">Duojiang</span>
			<span class="site-title">{SITE_TITLE}</span>
		</a>
		<div class="nav-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/travel">Travel</HeaderLink>
			<HeaderLink href="/micro">Micro</HeaderLink>
			<HeaderLink href="/reading">Reading</HeaderLink>
			<HeaderLink href="/notes">Notes</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		padding: 1rem 1.5rem 0;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		padding: 1rem 1.25rem;
		border: 1px solid rgba(var(--line), 0.7);
		border-radius: 999px;
		background: rgba(var(--surface), 0.82);
		backdrop-filter: blur(18px);
		box-shadow: 0 18px 36px rgba(var(--ink), 0.08);
	}

	.site-mark {
		display: grid;
		gap: 0.08rem;
		text-decoration: none;
	}

	.site-kicker {
		font-size: 0.68rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgb(var(--accent));
	}

	.site-title {
		font-family: "Avenir Next Condensed", "Arial Narrow", "Trebuchet MS", sans-serif;
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		color: rgb(var(--ink));
	}

	.nav-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: flex-end;
		gap: 0.4rem;
	}

	@media (max-width: 720px) {
		header {
			padding: 0.75rem;
		}

		nav {
			flex-direction: column;
			align-items: flex-start;
			border-radius: 26px;
		}

		.nav-links {
			justify-content: flex-start;
		}
	}
</style>
