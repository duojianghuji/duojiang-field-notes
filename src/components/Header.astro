---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header>
	<nav>
		<a class="site-mark" href={`${base}/`}>
			<span class="site-kicker">Duojiang</span>
			<span class="site-title">{SITE_TITLE}</span>
		</a>
		<div class="nav-links">
			<HeaderLink href={`${base}/`}>Home</HeaderLink>
			<HeaderLink href={`${base}/travel`}>Travel</HeaderLink>
			<HeaderLink href={`${base}/micro`}>Micro</HeaderLink>
			<HeaderLink href={`${base}/reading`}>Reading</HeaderLink>
			<HeaderLink href={`${base}/notes`}>Notes</HeaderLink>
			<HeaderLink href={`${base}/about`}>About</HeaderLink>
			<HeaderLink href="https://duojianghuji.github.io/duojiang-research-page/">Research</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.9rem 1.5rem;
		background: rgb(var(--nav));
		box-shadow: 0 1px 0 rgba(0, 0, 0, 0.08);
	}

	.site-mark {
		display: grid;
		gap: 0.08rem;
		text-decoration: none;
		color: white;
	}

	.site-kicker {
		font-size: 0.68rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.72);
	}

	.site-title {
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		color: white;
	}

	.nav-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: flex-end;
		gap: 1rem;
	}

	@media (max-width: 720px) {
		nav {
			flex-direction: column;
			align-items: flex-start;
			padding: 0.85rem 1rem;
		}

		.nav-links {
			justify-content: flex-start;
		}
	}
</style>
