---
import { getCollection } from 'astro:content';
import EntryCard from '../components/EntryCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import SiteLayout from '../layouts/SiteLayout.astro';

const sortEntries = (entries) =>
	entries
		.filter((entry) => !entry.data.draft)
		.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const [travel, micro, reading, notes] = await Promise.all([
	getCollection('travel'),
	getCollection('micro'),
	getCollection('reading'),
	getCollection('notes'),
]);

const recentEntries = [
	...sortEntries(travel),
	...sortEntries(micro),
	...sortEntries(reading),
	...sortEntries(notes),
]
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);
---

<SiteLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="landing-hero surface-card">
		<div class="hero-copy">
			<p class="eyebrow">Places, details, reading, and small observations</p>
			<h1>Duojiang Field Notes</h1>
			<p class="lede">
				A companion site for travel writing, micro photography, reading notes, and the kinds of details
				that are too alive to leave inside a folder.
			</p>
		</div>
		<div class="hero-aside">
			<div class="meta-card">
				<h3>Sections</h3>
				<p>Travel journal, micro photography, reading trail, and short notes.</p>
			</div>
			<div class="meta-card">
				<h3>Update rhythm</h3>
				<p>Light, regular additions instead of long gaps followed by big backlog uploads.</p>
			</div>
			<div class="meta-card">
				<h3>Editorial rule</h3>
				<p>Keep each entry small enough to finish and strong enough to remember.</p>
			</div>
		</div>
	</section>

	<section class="section-block">
		<p class="eyebrow">Browse</p>
		<h2>Four ways into the site</h2>
		<div class="section-grid">
			<a class="section-tile" href="/travel/">
				<h3>Travel</h3>
				<p>Place-based journal entries, short itineraries, and visual notes from movement.</p>
			</a>
			<a class="section-tile" href="/micro/">
				<h3>Micro</h3>
				<p>Close-looking work: tiny textures, patterns, surfaces, and the language of scale.</p>
			</a>
			<a class="section-tile" href="/reading/">
				<h3>Reading</h3>
				<p>A curated reading trail for books, essays, and references that sharpen observation.</p>
			</a>
			<a class="section-tile" href="/notes/">
				<h3>Notes</h3>
				<p>Short pieces that connect travel, images, reading, and everyday attention.</p>
			</a>
		</div>
	</section>

	<section class="section-block">
		<p class="eyebrow">Recent</p>
		<h2>Starter entries</h2>
		<p class="lede">
			The first entries establish the voice and structure of the site. They are meant to be replaced or
			built on as your own material grows.
		</p>
		<div class="entry-grid">
			{
				recentEntries.map((entry) => (
					<EntryCard
						href={`/${entry.collection}/${entry.id}/`}
						title={entry.data.title}
						description={entry.data.description}
						pubDate={entry.data.pubDate}
						tags={entry.data.tags}
						eyebrow={entry.collection}
					/>
				))
			}
		</div>
	</section>
</SiteLayout>

<style>
	.landing-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.9fr);
		gap: 1.5rem;
		padding: 2rem;
		border-radius: 36px;
	}

	.hero-aside {
		display: grid;
		gap: 1rem;
	}

	.section-block {
		margin-top: 4rem;
	}

	@media (max-width: 820px) {
		.landing-hero {
			grid-template-columns: 1fr;
			padding: 1.25rem;
		}
	}
</style>
