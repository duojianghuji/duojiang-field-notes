---
import FormattedDate from '../components/FormattedDate.astro';
import SiteLayout from './SiteLayout.astro';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	tags?: string[];
	sectionLabel: string;
}

const { title, description, pubDate, updatedDate, tags = [], sectionLabel } = Astro.props;
---

<SiteLayout title={`${title} | Duojiang Field Notes`} description={description}>
	<article class="entry surface-card">
		<p class="eyebrow">{sectionLabel}</p>
		<h1>{title}</h1>
		<p class="lede">{description}</p>
		<div class="entry-meta">
			<p><FormattedDate date={pubDate} /></p>
			{
				updatedDate && (
					<p>Updated <FormattedDate date={updatedDate} /></p>
				)
			}
			{
				tags.length > 0 && (
					<p>{tags.join(' · ')}</p>
				)
			}
		</div>
		<div class="prose">
			<slot />
		</div>
	</article>
</SiteLayout>

<style>
	.entry {
		padding: 1.8rem;
		border-radius: 38px;
	}

	.entry-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.3rem 1rem;
		margin-bottom: 2rem;
		color: rgb(var(--muted));
	}

	.entry-meta p {
		margin: 0;
	}

	@media (max-width: 720px) {
		.entry {
			padding: 1.2rem;
			border-radius: 28px;
		}
	}
</style>
